name: CI for SimpleJdbcMapper

on:
  push:
    branches: [ "dev" ]
    paths-ignore:
      - 'README.md'
  pull_request:
    branches: [ "dev" ]
    paths-ignore:
      - 'README.md'

jobs:
  tests-with-postgres:
    runs-on: ubuntu-latest

    # Define the PostgreSQL service container
    services:
      postgres:
        image: postgres:18
        env:
          POSTGRES_DB: sjm_postgres
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: pass1234
        ports:
          # Maps port 5432 on the service container to port 5432 on the runner host
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
    - name: Checkout code
      uses: actions/checkout@v6

    - name: Wait for PostgreSQL to be ready (optional, but recommended)
      # The 'services' health check in the 'options' above handles this, 
      # but this step provides an explicit wait within the main job's execution flow if needed.
      run: |
        while ! pg_isready -h localhost -p 5432; do
          sleep 2
        done

    - name: Set up JDK 21
      uses: actions/setup-java@v5 # Action to set up the Java environment 
      with:
        java-version: '21' # Specify the Java version required for the Spring project
        distribution: 'corretto' # Choose a JDK distribution (e.g., temurin, corretto, zulu)
        cache: maven # Enables caching of Maven dependencies to speed up subsequent runs

    - name: Run tests against postgres
      run: mvn clean package -Dspring.profiles.active=postgres

  tests-with-mysql:
    runs-on: ubuntu-latest
    services:
      mysql:
        image: mysql:8.0
        env:
          MYSQL_DATABASE: sjm_mysql
          MYSQL_ALLOW_EMPTY_PASSWORD: "yes"
        ports:
          - 3306:3306
        options: >-
          --health-cmd="mysqladmin ping"
          --health-interval=10s
          --health-timeout=5s
          --health-retries=3

    steps:
    - name: Checkout code
      uses: actions/checkout@v6

    - name: Set up JDK 21
      uses: actions/setup-java@v5 # Action to set up the Java environment 
      with:
        java-version: '21' # Specify the Java version required for the Spring project
        distribution: 'corretto' # Choose a JDK distribution (e.g., temurin, corretto, zulu)
        cache: maven # Enables caching of Maven dependencies to speed up subsequent runs

    - name: Run tests against mysql
      run: mvn clean package -Dspring.profiles.active=mysql  
      
      
jobs:
  tests-against-oracle:
    runs-on: ubuntu-latest

    services:
      # Oracle service (label used to access the service container)
      oracle:
        # Docker Hub image (feel free to change the tag "latest" to any other available one)
        image: gvenzl/oracle-free:latest

        # Provide passwords and other environment variables to container
        env:
          ORACLE_DATABASE: MYPDB
          ORACLE_PASSWORD: pass1234
          APP_USER: SCHEMA1
          APP_USER_PASSWORD: app

        # Forward Oracle port
        ports:
          - 1521:1521

        # Provide container name and healthcheck script options for startup
        options: >-
          --name oracle-db 
          --health-cmd healthcheck.sh
          --health-interval 10s
          --health-timeout 5s
          --health-retries 10

    steps:
    - name: create SCHEMA2 user
      run: docker exec oracle-db createAppUser SCHEMA2 app MYPDB
      
    - name: give privileges to SCHEMA2
      run: |
           docker exec oracle-db sqlplus sys/pass1234@localhost:1521/MYPDB as sysdba <<EOF
             GRANT ALL PRIVILEGES TO SCHEMA1;
             GRANT ALL PRIVILEGES TO SCHEMA2;           
             GRANT SELECT ANY TABLE ON SCHEMA SCHEMA2 TO SCHEMA1;
             GRANT INSERT ANY TABLE ON SCHEMA SCHEMA2 TO SCHEMA1;
             GRANT UPDATE ANY TABLE ON SCHEMA SCHEMA2 TO SCHEMA1;
             GRANT DELETE ANY TABLE ON SCHEMA SCHEMA2 TO SCHEMA1;
             GRANT SELECT ANY TABLE ON SCHEMA SCHEMA1 TO SCHEMA2;
             GRANT INSERT ANY TABLE ON SCHEMA SCHEMA1 TO SCHEMA2;
             GRANT UPDATE ANY TABLE ON SCHEMA SCHEMA1 TO SCHEMA2;
             GRANT DELETE ANY TABLE ON SCHEMA SCHEMA1 TO SCHEMA2;
              EXIT;
           EOF
      
    - name: Checkout code
      uses: actions/checkout@v6

    - name: Set up JDK 21
      uses: actions/setup-java@v5 # Action to set up the Java environment 
      with:
        java-version: '21' # Specify the Java version required for the Spring project
        distribution: 'corretto' # Choose a JDK distribution (e.g., temurin, corretto, zulu)
        cache: maven # Enables caching of Maven dependencies to speed up subsequent runs

    - name: Run tests against oracle
      #run: mvn clean package -Dspring.profiles.active=oracle
      
      run: mvn clean test -Dtest=TableAnnotationWithSchemaTest -Dspring.profiles.active=oracle          

